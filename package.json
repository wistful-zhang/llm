{
  "name": "llm-interview-notes",
  "version": "1.3.0",
  "private": true,
  "description": "可复用的大模型面试题库、模拟面试与复盘网站",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "validate": "node scripts/validate-content.mjs",
    "questions:expand": "node scripts/build-question-expansion.mjs --write",
    "questions:expand:check": "node scripts/build-question-expansion.mjs",
    "questions:audit": "node scripts/audit-question-similarity.mjs",
    "check": "npm run validate && npm test"
  }
}
